<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>الملف الشخصي - همة</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&family=Tajawal:wght@300;400;500;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #2E5A4B;
            --primary-light: #3D7A65;
            --primary-soft: #E9F1ED;
            --accent: #C59B3F;
            --accent-light: #DFB85A;
            --accent-soft: #FBF5E8;
            --bg: #F7F5F0;
            --surface: #FFFFFF;
            --surface-alt: #F1EFE8;
            --text: #1F1F1F;
            --text-secondary: #5A5A5A;
            --text-muted: #8A8A8A;
            --border: #E0DCD2;
            --border-light: #F0EDE4;
            --shadow-xs: 0 1px 2px rgba(0,0,0,0.03);
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
            --shadow: 0 8px 24px rgba(0,0,0,0.06);
            --shadow-lg: 0 16px 40px rgba(0,0,0,0.08);
            --radius-sm: 10px;
            --radius: 16px;
            --radius-lg: 24px;
            --radius-xl: 32px;
            --transition: 0.25s cubic-bezier(0.4,0,0.2,1);
            --font-heading: 'Cairo', sans-serif;
            --font-body: 'Tajawal', sans-serif;
            --header-height: 76px;
        }

        [data-theme="dark"] {
            --bg: #171D1B;
            --surface: #212927;
            --surface-alt: #262E2A;
            --text: #EAECEB;
            --text-secondary: #B5BCB8;
            --text-muted: #808B85;
            --border: #37423D;
            --border-light: #2D3631;
            --primary-soft: #263D33;
            --accent-soft: #3E3524;
        }

        * { margin:0; padding:0; box-sizing:border-box; }
        body {
            font-family: var(--font-body);
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
            min-height: 100vh;
            transition: background-color 0.4s, color 0.4s;
            display: flex;
            flex-direction: column;
        }
        a { color: inherit; text-decoration: none; }

        /* Header */
        .header {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-bottom: 1px solid var(--border);
            height: var(--header-height);
            display: flex;
            align-items: center;
            padding: 0 32px;
            box-shadow: var(--shadow-xs);
            transition: background 0.4s;
        }
        [data-theme="dark"] .header { background: rgba(33,41,39,0.85); }
        .header-inner {
            max-width: 1300px;
            width: 100%;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
        }
        .logo { display:flex; align-items:center; gap:10px; }
        .logo-icon {
            width:42px; height:42px;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            border-radius:12px;
            display:flex; align-items:center; justify-content:center;
            color:#fff; font-size:1.4rem; font-weight:800;
            font-family: var(--font-heading);
            box-shadow:0 4px 12px rgba(46,90,75,0.2);
        }
        .logo-text { font-family: var(--font-heading); font-size:1.5rem; font-weight:800; color:var(--primary); }
        .logo-text span { color:var(--accent); }
        .nav-links { display:flex; align-items:center; gap:4px; list-style:none; }
        .nav-links a {
            padding:10px 18px; border-radius:28px;
            font-weight:500; color:var(--text-secondary);
            transition:0.2s; font-size:0.95rem;
        }
        .nav-links a:hover,
        .nav-links a.active { background:var(--primary-soft); color:var(--primary); }
        .nav-links a.active { font-weight:700; }
        .header-actions { display:flex; align-items:center; gap:12px; flex-shrink:0; }
        .btn {
            display:inline-flex; align-items:center; gap:8px;
            padding:11px 24px; border-radius:30px; font-weight:600;
            font-size:0.9rem; cursor:pointer; border:none; transition:0.2s;
        }
        .btn-primary { background:var(--primary); color:#fff; box-shadow:0 4px 14px rgba(46,90,75,0.25); }
        .btn-primary:hover { background:var(--primary-light); transform:translateY(-1px); }
        .btn-outline { background:transparent; color:var(--primary); border:2px solid var(--primary); }
        .btn-outline:hover { background:var(--primary); color:#fff; }
        .theme-toggle {
            width:42px; height:42px; border-radius:50%; border:1px solid var(--border);
            background:var(--surface); cursor:pointer; font-size:1.2rem;
            display:flex; align-items:center; justify-content:center;
            transition:0.2s; color:var(--text-secondary);
        }
        .theme-toggle:hover { border-color:var(--accent); color:var(--accent); }
        .mobile-menu-btn { display:none; background:none; border:none; font-size:1.8rem; cursor:pointer; color:var(--text); }
        .mobile-nav {
            display:none; position:fixed; top:var(--header-height); left:0; right:0; bottom:0;
            background:var(--surface); z-index:999; flex-direction:column; padding:24px; gap:6px;
            transform:translateX(100%); transition:transform 0.35s;
        }
        .mobile-nav.open { transform:translateX(0); display:flex; }
        .mobile-nav a { padding:15px 20px; font-weight:600; border-radius:var(--radius-sm); font-size:1.05rem; }
        .mobile-nav a.active,
        .mobile-nav a:hover { background:var(--primary-soft); color:var(--primary); }

        @media (max-width:920px) {
            .nav-links { display:none; }
            .header-actions .btn { display:none; }
            .mobile-menu-btn { display:flex; align-items:center; }
            .mobile-nav { display:flex; }
        }

        .main {
            flex:1;
            max-width: 900px;
            margin: 40px auto;
            padding: 0 24px;
            width: 100%;
        }

        .profile-card {
            background: var(--surface);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border);
            padding: 40px;
            box-shadow: var(--shadow);
            margin-bottom: 32px;
            text-align: center;
        }
        .avatar-circle {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            color: #fff;
            font-size: 2.8rem;
            font-weight: 800;
            font-family: var(--font-heading);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            box-shadow: 0 8px 24px rgba(46,90,75,0.3);
        }
        .profile-card h2 {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1.8rem;
            margin-bottom: 6px;
        }
        .profile-card .username {
            color: var(--text-secondary);
            font-size: 1rem;
            margin-bottom: 16px;
        }
        .info-grid {
            display: flex;
            justify-content: center;
            gap: 24px;
            flex-wrap: wrap;
            margin-bottom: 24px;
        }
        .info-item {
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--text-secondary);
            font-weight: 500;
        }
        .points-badge {
            background: var(--accent-soft);
            color: var(--accent);
            padding: 8px 24px;
            border-radius: 30px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 1.1rem;
        }

        .stats-row {
            display: flex;
            gap: 20px;
            margin-bottom: 32px;
        }
        .stat-box {
            flex:1;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            text-align: center;
            box-shadow: var(--shadow-sm);
        }
        .stat-box .num {
            font-family: var(--font-heading);
            font-size: 2rem;
            font-weight: 800;
            color: var(--primary);
        }
        .stat-box .label {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        .section-title {
            font-family: var(--font-heading);
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 16px;
        }
        .initiative-list {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .initiative-item {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: var(--shadow-sm);
            transition: all var(--transition);
        }
        .initiative-item:hover {
            box-shadow: var(--shadow);
            border-color: var(--primary-light);
        }
        .initiative-item .name {
            font-weight: 700;
            font-family: var(--font-heading);
        }
        .initiative-item .meta {
            font-size: 0.85rem;
            color: var(--text-muted);
        }
        .empty-state {
            text-align: center;
            color: var(--text-muted);
            padding: 32px;
        }

        .toast-container {
            position:fixed; top:20px; left:50%; transform:translateX(-50%);
            z-index:9999; display:flex; flex-direction:column; gap:8px;
            pointer-events:none;
        }
        .toast {
            padding:12px 24px; border-radius:28px; font-weight:600;
            box-shadow:0 8px 24px rgba(0,0,0,0.12);
            animation: toastIn 0.35s ease, toastOut 0.35s 2.8s ease forwards;
            pointer-events:auto;
        }
        .toast-success { background:#2D6A4F; color:#fff; }
        .toast-error { background:#C44545; color:#fff; }
        @keyframes toastIn { from{opacity:0;transform:translateY(-20px);} }
        @keyframes toastOut { to{opacity:0;transform:translateY(-10px);} }
    </style>
</head>
<body>

    <header class="header">
        <div class="header-inner">
            <a href="index.html" class="logo">
                <div class="logo-icon">ه</div>
                <div class="logo-text">هم<span>ة</span></div>
            </a>
            <nav class="nav-links">
                <a href="index.html">الرئيسية</a>
                <a href="initiatives.html">المبادرات</a>
                <a href="about.html">عن المنصة</a>
                <a href="redeem.html">المكافآت</a>
            </nav>
            <div class="header-actions">
                <button class="theme-toggle" id="themeToggle">🌙</button>
                <span id="loggedOutBtns">
                    <a href="signin.html" class="btn btn-outline">دخول</a>
                    <a href="signup.html" class="btn btn-primary">تسجيل</a>
                </span>
                <span id="loggedInBtns" class="hidden">
                    <div class="user-dropdown">
                        <button class="user-avatar-btn" id="userAvatarBtn" style="width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg, var(--primary), var(--primary-light));color:#fff;border:2px solid var(--primary-light);cursor:pointer;font-weight:700;">👤</button>
                        <div class="dropdown-menu" id="dropdownMenu" style="position:absolute;top:calc(100%+12px);left:0;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-lg);min-width:220px;opacity:0;visibility:hidden;transform:translateY(-8px);transition:0.25s;z-index:100;overflow:hidden;">
                            <a href="dashboard.html">📊 لوحة التحكم</a>
                            <a href="profile.html">👤 الملف الشخصي</a>
                            <a href="create-initiative.html">✨ إنشاء مبادرة</a>
                            <a href="#" id="signOutBtn" class="danger">🚪 تسجيل الخروج</a>
                        </div>
                    </div>
                </span>
                <button class="mobile-menu-btn" id="mobileMenuBtn">☰</button>
            </div>
        </div>
    </header>

    <nav class="mobile-nav" id="mobileNav">
        <a href="index.html">الرئيسية</a>
        <a href="initiatives.html">المبادرات</a>
        <a href="about.html">عن المنصة</a>
        <a href="redeem.html">المكافآت</a>
        <a href="signin.html">تسجيل الدخول</a>
        <a href="signup.html">إنشاء حساب</a>
    </nav>

    <main class="main">
        <!-- Profile will be injected here -->
        <div id="profileContent" class="loading-placeholder">جاري تحميل الملف الشخصي...</div>
    </main>

    <div class="toast-container" id="toastContainer"></div>

    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
    <script>
        (function() {
            const firebaseConfig = {
                apiKey: "AIzaSyDemoKeyForHimmah",
                authDomain: "himmah-jo.firebaseapp.com",
                projectId: "himmah-jo",
                storageBucket: "himmah-jo.appspot.com",
                messagingSenderId: "111111111111",
                appId: "1:111111111111:web:abc123"
            };

            if (!firebase.apps.length) firebase.initializeApp(firebaseConfig);
            const auth = firebase.auth();
            const db = firebase.firestore();

            const themeToggle = document.getElementById('themeToggle');
            const mobileBtn = document.getElementById('mobileMenuBtn');
            const mobileNav = document.getElementById('mobileNav');
            const loggedOutBtns = document.getElementById('loggedOutBtns');
            const loggedInBtns = document.getElementById('loggedInBtns');
            const userAvatarBtn = document.getElementById('userAvatarBtn');
            const dropdownMenu = document.getElementById('dropdownMenu');
            const signOutBtn = document.getElementById('signOutBtn');
            const toastContainer = document.getElementById('toastContainer');
            const profileContent = document.getElementById('profileContent');

            function showToast(msg, type = 'info') {
                const t = document.createElement('div');
                t.className = `toast toast-${type}`;
                t.textContent = msg;
                toastContainer.appendChild(t);
                setTimeout(() => t.remove(), 3400);
            }

            // Theme
            const savedTheme = localStorage.getItem('himmah-theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
            updateIcon(savedTheme);
            themeToggle.addEventListener('click', () => {
                const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('himmah-theme', next);
                updateIcon(next);
            });
            function updateIcon(t) { themeToggle.textContent = t === 'dark' ? '☀️' : '🌙'; }

            // Mobile
            mobileBtn.addEventListener('click', () => {
                mobileNav.classList.toggle('open');
                mobileBtn.textContent = mobileNav.classList.contains('open') ? '✕' : '☰';
            });
            document.querySelectorAll('.mobile-nav a').forEach(a => a.addEventListener('click', () => {
                mobileNav.classList.remove('open');
                mobileBtn.textContent = '☰';
            }));

            // Dropdown
            if (userAvatarBtn) {
                userAvatarBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    dropdownMenu.classList.toggle('show');
                });
                document.addEventListener('click', () => dropdownMenu.classList.remove('show'));
            }

            // Auth
            auth.onAuthStateChanged(async (user) => {
                if (!user) {
                    window.location.href = 'signin.html';
                    return;
                }
                loggedOutBtns.classList.add('hidden');
                loggedInBtns.classList.remove('hidden');
                const initial = (user.displayName || user.email || 'م')[0];
                userAvatarBtn.textContent = initial;
                await loadProfile(user.uid);
            });

            signOutBtn.addEventListener('click', async (e) => {
                e.preventDefault();
                await auth.signOut();
            });

            async function loadProfile(uid) {
                try {
                    const userDoc = await db.collection('users').doc(uid).get();
                    if (!userDoc.exists) {
                        showToast('المستخدم غير موجود', 'error');
                        return;
                    }
                    const userData = userDoc.data();
                    // Calculate age
                    const birthDate = userData.birthdate ? new Date(userData.birthdate) : null;
                    let age = '';
                    if (birthDate) {
                        const today = new Date();
                        let years = today.getFullYear() - birthDate.getFullYear();
                        const m = today.getMonth() - birthDate.getMonth();
                        if (m < 0 || (m === 0 && today.getDate() < birthDate.getDate())) years--;
                        age = years + ' سنة';
                    }

                    // Stats: joined initiatives count, created count
                    const [joinedSnap, createdSnap] = await Promise.all([
                        db.collection('participations').where('userId', '==', uid).where('status', 'in', ['joined', 'attended']).get(),
                        db.collection('initiatives').where('createdBy', '==', uid).get()
                    ]);
                    const joinedCount = joinedSnap.size;
                    const createdCount = createdSnap.size;

                    // Get joined initiatives details
                    const joinedInitiatives = [];
                    for (const doc of joinedSnap.docs) {
                        const p = doc.data();
                        const initDoc = await db.collection('initiatives').doc(p.initiativeId).get();
                        if (initDoc.exists) {
                            joinedInitiatives.push({ id: initDoc.id, ...initDoc.data() });
                        }
                    }
                    // Get created initiatives
                    const createdInitiatives = createdSnap.docs.map(d => ({ id: d.id, ...d.data() }));

                    renderProfile(userData, age, joinedCount, createdCount, joinedInitiatives, createdInitiatives);
                } catch (e) {
                    console.error(e);
                    profileContent.innerHTML = '<div class="empty-state">حدث خطأ أثناء تحميل البيانات</div>';
                }
            }

            function renderProfile(userData, age, joinedCount, createdCount, joinedInitiatives, createdInitiatives) {
                const avatarLetter = (userData.username || 'م')[0];
                const username = userData.username || 'غير معروف';
                const city = userData.city || '';
                const gender = userData.gender || '';
                const bio = userData.bio || 'لا يوجد وصف';
                const points = userData.points || 0;

                let html = `
                    <div class="profile-card">
                        <div class="avatar-circle">${avatarLetter}</div>
                        <h2>${username}</h2>
                        <div class="username">@${username}</div>
                        <div class="info-grid">
                            ${gender ? `<div class="info-item"><i class="fa-solid fa-venus-mars"></i> ${gender}</div>` : ''}
                            ${city ? `<div class="info-item"><i class="fa-solid fa-map-pin"></i> ${city}</div>` : ''}
                            ${age ? `<div class="info-item"><i class="fa-solid fa-cake-candles"></i> ${age}</div>` : ''}
                        </div>
                        <div class="points-badge">
                            <i class="fa-solid fa-star"></i> ${points} نقطة
                        </div>
                        <p style="margin-top:16px; color:var(--text-secondary);">${bio}</p>
                    </div>
                    <div class="stats-row">
                        <div class="stat-box">
                            <div class="num">${joinedCount}</div>
                            <div class="label">مبادرة منضم إليها</div>
                        </div>
                        <div class="stat-box">
                            <div class="num">${createdCount}</div>
                            <div class="label">مبادرة أنشأتها</div>
                        </div>
                    </div>
                    <div class="section-title">📋 المبادرات التي انضممت إليها</div>
                    <div class="initiative-list" id="joinedList">
                        ${joinedInitiatives.length === 0 ? '<div class="empty-state">لم تنضم لأي مبادرة بعد</div>' : ''}
                    </div>
                    <div class="section-title" style="margin-top:32px;">✨ المبادرات التي أنشأتها</div>
                    <div class="initiative-list" id="createdList">
                        ${createdInitiatives.length === 0 ? '<div class="empty-state">لم تنشئ أي مبادرة بعد</div>' : ''}
                    </div>
                `;
                profileContent.innerHTML = html;

                // Populate joined initiatives
                const joinedContainer = document.getElementById('joinedList');
                if (joinedInitiatives.length > 0) {
                    joinedInitiatives.forEach(init => {
                        const div = document.createElement('div');
                        div.className = 'initiative-item';
                        div.innerHTML = `
                            <div>
                                <div class="name">${init.name}</div>
                                <div class="meta">${init.date} | ${init.city}</div>
                            </div>
                            <a href="initiative-detail.html?id=${init.id}" class="btn btn-outline btn-sm">عرض</a>
                        `;
                        joinedContainer.appendChild(div);
                    });
                }
                // Populate created initiatives
                const createdContainer = document.getElementById('createdList');
                if (createdInitiatives.length > 0) {
                    createdInitiatives.forEach(init => {
                        const div = document.createElement('div');
                        div.className = 'initiative-item';
                        div.innerHTML = `
                            <div>
                                <div class="name">${init.name}</div>
                                <div class="meta">${init.date} | ${init.city} | ${init.status === 'approved' ? '✅ معتمدة' : init.status === 'pending' ? '⏳ قيد المراجعة' : '❌ مرفوضة'}</div>
                            </div>
                            <a href="initiative-detail.html?id=${init.id}" class="btn btn-outline btn-sm">عرض</a>
                        `;
                        createdContainer.appendChild(div);
                    });
                }
            }
        })();
    </script>
</body>
</html>
